  let currentScenario = 0;
  let completed = new Array(scenarios.length).fill(false);

  const scenarioView = document.getElementById('scenarioView');
  const completionCard = document.getElementById('completion');
  const trackerPips = document.getElementById('trackerPips');
  const trackerCount = document.getElementById('trackerCount');

  // Build tracker
  function renderTracker() {
    trackerPips.innerHTML = '';
    scenarios.forEach((_, i) => {
      const pip = document.createElement('div');
      pip.className = 'pip';
      if (i === currentScenario) pip.classList.add('active');
      if (completed[i]) pip.classList.add('complete');
      trackerPips.appendChild(pip);
    });
    trackerCount.textContent = `${currentScenario + 1} / ${scenarios.length}`;
  }

  function renderScenario(index) {
    const s = scenarios[index];
    scenarioView.innerHTML = `
      <div class="stage-label">
        <div class="dot"></div>
        <span>Scenario <span class="scenario-tag">${index + 1} of ${scenarios.length}</span></span>
        <div class="line"></div>
      </div>

      <div class="scenario" data-label="${s.label}">
        <div class="scenario-title">${s.title}</div>
        <p class="scenario-text">${s.text}</p>
        <div class="time-pressure">${s.timing}</div>
      </div>

      <div class="prompt">
        <p class="prompt-text">What do you do?</p>
      </div>

      <div class="choices">
        ${s.choices.map(c => `
          <button class="choice" data-choice="${c.key}">
            <span class="choice-letter">${c.key}</span>
            <span>${c.text}</span>
          </button>
        `).join('')}
      </div>

      <div class="feedback"></div>

      <div class="controls">
        <button class="btn" id="tryAgainBtn">↻ Try another choice</button>
        <button class="btn primary" id="nextBtn" disabled>${index === scenarios.length - 1 ? 'Finish →' : 'Next scenario →'}</button>
      </div>
    `;

    attachHandlers(s);
    renderTracker();
  }

  function attachHandlers(scenarioData) {
    const choiceButtons = scenarioView.querySelectorAll('.choice');
    const feedbackEl = scenarioView.querySelector('.feedback');
    const tryAgainBtn = scenarioView.querySelector('#tryAgainBtn');
    const nextBtn = scenarioView.querySelector('#nextBtn');
    const controls = scenarioView.querySelector('.controls');

    choiceButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.choice;
        const choice = scenarioData.choices.find(c => c.key === key);

        choiceButtons.forEach(c => {
          c.disabled = true;
          c.classList.remove('selected');
        });
        btn.classList.add('selected');

        feedbackEl.innerHTML = `
          <div class="verdict ${choice.verdictClass}">
            <span>${choice.verdictLabel}</span>
          </div>
          <div class="feedback-body">
            <div class="feedback-label">What this teaches the athlete</div>
            ${choice.analysis.map(p => `<p class="feedback-text">${p}</p>`).join('')}
          </div>
          <div class="danielle-says">
            ${choice.danielle.map(p => `<p>${p}</p>`).join('')}
          </div>
        `;
        feedbackEl.classList.add('visible');
        controls.classList.add('visible');
        nextBtn.disabled = false;
        completed[currentScenario] = true;
        renderTracker();

        setTimeout(() => {
          feedbackEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      });
    });

    tryAgainBtn.addEventListener('click', () => {
      choiceButtons.forEach(c => {
        c.disabled = false;
        c.classList.remove('selected');
      });
      feedbackEl.classList.remove('visible');
      feedbackEl.innerHTML = '';
      scenarioView.querySelector('.scenario').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    nextBtn.addEventListener('click', () => {
      if (currentScenario < scenarios.length - 1) {
        currentScenario++;
        renderScenario(currentScenario);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        // Show completion
        scenarioView.style.display = 'none';
        completionCard.classList.add('visible');
        document.querySelector('.tracker').style.display = 'none';
        completionCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  document.getElementById('restartBtn').addEventListener('click', () => {
    currentScenario = 0;
    completed = new Array(scenarios.length).fill(false);
    completionCard.classList.remove('visible');
    scenarioView.style.display = 'block';
    document.querySelector('.tracker').style.display = 'flex';
    renderScenario(0);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Init
  renderScenario(0);
</script>
